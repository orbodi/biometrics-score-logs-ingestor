DB_HOST=localhost

DB_PORT=5432

DB_NAME=biometrics

DB_USER=biometrics_user

DB_PASSWORD=change_me

DB_SCHEMA=public



# Initialiser le schéma PostgreSQL (table biometric_scores) au lancement du script

INIT_DB=false



LOG_LEVEL=INFO



# Répertoire racine — les sous-dossiers sont créés automatiquement :

#   inputs/        fichiers .log collectés

#   outputs/       fichiers JSONL générés

#   archive/       .log archivés après parsing

#   archive_json/  JSONL archivés après persistance

#   logs/          logs d'exécution

#   errors/        copies de secours en cas d'échec

#   state/         base SQLite de suivi (ingestor_state.db)

ROOT_DIR=data



# Fichier JSON décrivant les serveurs SSH (nom, IP/host, remote_dir)

# Voir l'exemple dans `servers.example.json`

SSH_SERVERS_FILE=servers.example.json



# Identifiants SSH utilisés pour se connecter aux serveurs

SSH_USER=your_ssh_username

SSH_PASSWORD=your_ssh_password



# Timeout pour les connexions SSH (en secondes, défaut: 30)

SSH_TIMEOUT=30



# Retry base de données (erreurs transitoires : connexion, timeout)

DB_RETRY_MAX_ATTEMPTS=3

DB_RETRY_DELAY_SECONDS=2.0

DB_RETRY_BACKOFF=2.0



# Purge automatique si espace disque insuffisant

DISK_PURGE_ENABLED=true

DISK_MIN_FREE_MB=500

DISK_PURGE_TARGET_FREE_MB=1024

DISK_PURGE_MAX_FILES=500

# Octroi automatique des droits (fichiers, PostgreSQL, SSH)
AUTO_GRANT_PERMISSIONS=true
DIR_PERMISSION_MODE=775
FILE_PERMISSION_MODE=664
SSH_AUTO_ACCEPT_HOST_KEY=true

